# ── LoveWish backend configuration ──────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Port the API listens on.
PORT=3000

# Set to "production" in production so error details are not leaked and
# weak admin credentials are rejected at startup.
NODE_ENV=development

# JWT signing secret. MUST be long and random (>= 32 chars).
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-secret

# Initial admin account created by `npm run seed`.
# In production the password MUST be >= 12 chars and not a common password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Comma-separated list of allowed browser origins (CORS).
CORS_ORIGINS=http://localhost:4200
